# Copy to .env and fill in your values

# Anthropic API key (required)
ANTHROPIC_API_KEY=your_key_here

# Semantic Scholar API key (optional — higher rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# eLIBRARY.ru API token (required for Elibrary source)
# Register at: https://elibrary.ru/projects/api/api_info.asp
ELIBRARY_API_TOKEN=

# MDPI CrossRef polite pool email (recommended)
MAILTO=your_email@example.com

# Prompts directory (default: ./prompts)
PROMPTS_DIR=./prompts

# Output directory (default: ./output)
OUTPUT_DIR=./output
